{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://contracts.shangmeizhiying.local/api/ai-task-result.v1.schema.json",
  "title": "AI Task Result v1",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "task_id", "attempt", "status", "ai_trace_id", "usage"],
  "properties": {
    "schema_version": { "const": "ai-task-result.v1" },
    "task_id": { "type": "string", "format": "uuid" },
    "attempt": { "type": "integer", "minimum": 1 },
    "status": {
      "type": "string",
      "enum": ["succeeded", "retryable_failure", "permanent_failure", "cancelled"]
    },
    "output_schema": { "type": "string", "minLength": 1, "maxLength": 128 },
    "output": { "type": "object" },
    "evidence_refs": {
      "type": "array",
      "maxItems": 200,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["kind", "id", "version"],
        "properties": {
          "kind": { "type": "string", "minLength": 1, "maxLength": 64 },
          "id": { "type": "string", "minLength": 1, "maxLength": 128 },
          "version": { "type": "string", "minLength": 1, "maxLength": 64 },
          "locator": { "type": "string", "maxLength": 512 }
        }
      }
    },
    "ai_trace_id": { "type": "string", "format": "uuid" },
    "usage": {
      "type": "object",
      "additionalProperties": false,
      "required": ["input_tokens", "output_tokens", "cost_micros", "duration_ms"],
      "properties": {
        "input_tokens": { "type": "integer", "minimum": 0 },
        "output_tokens": { "type": "integer", "minimum": 0 },
        "cost_micros": { "type": "integer", "minimum": 0 },
        "duration_ms": { "type": "integer", "minimum": 0 }
      }
    },
    "error": {
      "type": "object",
      "additionalProperties": false,
      "required": ["code", "category", "message"],
      "properties": {
        "code": { "type": "string", "pattern": "^[A-Z0-9_]+$" },
        "category": {
          "type": "string",
          "enum": ["validation", "authorization", "dependency", "rate_limit", "timeout", "provider", "cancelled", "internal"]
        },
        "message": { "type": "string", "maxLength": 1000 },
        "retry_after_ms": { "type": "integer", "minimum": 0 }
      }
    }
  },
  "allOf": [
    {
      "if": { "properties": { "status": { "const": "succeeded" } } },
      "then": { "required": ["output_schema", "output", "evidence_refs"] },
      "else": { "required": ["error"] }
    }
  ]
}
