{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://contracts.shangmeizhiying.local/observability/ai-trace.v1.schema.json",
  "title": "AI Trace v1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "ai_trace_id",
    "trace_id",
    "tenant_id",
    "purpose",
    "prompt",
    "model",
    "tools",
    "evidence_refs",
    "usage",
    "outcome",
    "started_at",
    "finished_at"
  ],
  "properties": {
    "schema_version": { "const": "ai-trace.v1" },
    "ai_trace_id": { "type": "string", "format": "uuid" },
    "trace_id": { "type": "string", "format": "uuid" },
    "tenant_id": { "type": "string", "format": "uuid" },
    "purpose": { "type": "string", "minLength": 3, "maxLength": 128 },
    "prompt": {
      "type": "object",
      "additionalProperties": false,
      "required": ["prompt_id", "version", "input_sha256"],
      "properties": {
        "prompt_id": { "type": "string", "minLength": 1, "maxLength": 128 },
        "version": { "type": "integer", "minimum": 1 },
        "input_sha256": { "type": "string", "pattern": "^[0-9a-f]{64}$" }
      }
    },
    "model": {
      "type": "object",
      "additionalProperties": false,
      "required": ["deployment_id", "provider", "model_id"],
      "properties": {
        "deployment_id": { "type": "string", "minLength": 1, "maxLength": 128 },
        "provider": { "type": "string", "minLength": 1, "maxLength": 64 },
        "model_id": { "type": "string", "minLength": 1, "maxLength": 128 }
      }
    },
    "tools": {
      "type": "array",
      "maxItems": 100,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["name", "status", "duration_ms"],
        "properties": {
          "name": { "type": "string", "minLength": 1, "maxLength": 128 },
          "status": { "type": "string", "enum": ["succeeded", "failed", "denied"] },
          "duration_ms": { "type": "integer", "minimum": 0 },
          "arguments_sha256": { "type": "string", "pattern": "^[0-9a-f]{64}$" }
        }
      }
    },
    "evidence_refs": {
      "type": "array",
      "maxItems": 200,
      "items": { "type": "string", "minLength": 1, "maxLength": 512 }
    },
    "usage": {
      "type": "object",
      "additionalProperties": false,
      "required": ["input_tokens", "output_tokens", "cost_micros"],
      "properties": {
        "input_tokens": { "type": "integer", "minimum": 0 },
        "output_tokens": { "type": "integer", "minimum": 0 },
        "cost_micros": { "type": "integer", "minimum": 0 }
      }
    },
    "outcome": { "type": "string", "enum": ["succeeded", "failed", "blocked", "cancelled"] },
    "started_at": { "type": "string", "format": "date-time" },
    "finished_at": { "type": "string", "format": "date-time" }
  }
}
