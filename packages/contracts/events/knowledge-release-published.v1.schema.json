{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://contracts.shangmeizhiying.local/events/knowledge-release-published.v1.schema.json",
  "title": "Knowledge Release Published v1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "event_id",
    "tenant_id",
    "aggregate_id",
    "aggregate_version",
    "occurred_at",
    "purpose",
    "document_versions"
  ],
  "properties": {
    "schema_version": { "const": "knowledge-release-published.v1" },
    "event_id": { "type": "string", "format": "uuid" },
    "tenant_id": { "type": "string", "format": "uuid" },
    "aggregate_id": { "type": "string", "format": "uuid" },
    "aggregate_version": { "type": "integer", "minimum": 1 },
    "occurred_at": { "type": "string", "format": "date-time" },
    "purpose": { "type": "string", "minLength": 3, "maxLength": 128 },
    "document_versions": {
      "type": "array",
      "minItems": 1,
      "maxItems": 10000,
      "uniqueItems": true,
      "items": { "type": "string", "minLength": 1, "maxLength": 128 }
    },
    "index_projection": {
      "type": "object",
      "additionalProperties": false,
      "required": ["status"],
      "properties": {
        "status": { "type": "string", "enum": ["not_connected", "requested"] },
        "embedding_model": { "type": "string", "maxLength": 128 },
        "dimension": { "type": "integer", "minimum": 1 },
        "chunker_version": { "type": "string", "maxLength": 64 }
      }
    }
  }
}
