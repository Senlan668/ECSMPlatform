# ============================================================
# Docker 构建排除列表
# 仅复制后端运行所需的文件到镜像中
# ============================================================

# 前端（排除构建产物和依赖，源码保留给 nginx.dockerfile 多阶段构建）
frontend/node_modules/
frontend/dist/
frontend/.vercel/

# Python 虚拟环境
app/venv/
venv/
.venv/
ENV/

# Python 缓存
__pycache__/
**/__pycache__/
*.py[cod]
*$py.class
*.egg-info/

# Git
.git/
.gitignore

# IDE
.idea/
.vscode/
*.swp
*.swo

# 日志和临时文件
logs/
*.log
tmp/
temp/

# 环境变量文件（敏感信息通过 SAE 环境变量注入）
.env
.env.local
.env.*.local

# 测试
.pytest_cache/
.coverage
htmlcov/
test_*.py

# 文档
*.md
docs/

# 操作系统
.DS_Store
Thumbs.db

# 静态文件（运行时生成）
static/
